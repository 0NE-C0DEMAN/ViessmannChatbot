# ─────────────────────────────────────────────────────────────────────────────
# Viessmann RAG Chatbot — environment configuration
#
# 1. Copy this file to `.env`:           cp .env.example .env
# 2. Fill in the values below.
# 3. `.env` is gitignored — never commit your real keys.
#
# Quick map of what you need:
#   - Supabase project (URL + service-role key)
#   - OpenAI API key with billing credit (~$10 covers ingest + a lot of chat)
#   - Google Drive root folder ID (the folder that contains your PDF subfolders)
#   - EITHER:
#       (A) a service-account JSON file at the repo root → headless, no expiry
#       (B) OAuth client_id + secret → browser consent on first run
# ─────────────────────────────────────────────────────────────────────────────


# ── Chat server (login + port) ──────────────────────────────────────────────
CHAT_USERNAME=viessmann
CHAT_PASSWORD=carrier
FLASK_SECRET_KEY=change-me-to-a-random-string
CHAT_PORT=8081


# ── Supabase (Postgres + pgvector) ──────────────────────────────────────────
# From: https://supabase.com/dashboard/project/<your-project>/settings/api
#   - "Project URL"       → SUPABASE_URL
#   - "service_role" key  → SUPABASE_SERVICE_KEY  (server-side only — never
#                                                  expose in a browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...


# ── OpenAI ──────────────────────────────────────────────────────────────────
# Get an API key: https://platform.openai.com/api-keys
# Make sure the account has billing credit — this app uses:
#   text-embedding-3-small  (ingest, ~$0.05 for the full Vitocal corpus)
#   gpt-4o-mini             (intent classifier, query expansion, rerank, HyDE)
#   gpt-4o                  (final answers, the expensive part)
# Per-question cost: ~$0.09; ingest cost is one-time and trivial.
OPENAI_API_KEY=sk-proj-...


# ── Google Drive ingest (only required when running `ingest.py --drive`) ────
# This is the folder containing all your product subfolders (e.g. "Viessmann"
# with "Vitocal 100-S/", "Vitocal 200-S/" inside).
# Get the ID from the Drive URL: drive.google.com/drive/folders/<THIS_PART>
GOOGLE_ROOT_FOLDER_ID=

# Polling interval for `ingest.py --drive --loop` (continuous mode).
POLL_INTERVAL_SECONDS=60


# ── Pick ONE Drive auth mode (A or B) ───────────────────────────────────────
#
# ▸ MODE A — Service account (recommended for production)
#
#   1. Create a service account:
#         https://console.cloud.google.com/iam-admin/serviceaccounts
#      → "+ Create service account" → fill name → Done.
#   2. Open the new SA → "Keys" tab → "Add Key" → "Create new key" → JSON.
#   3. Save the downloaded JSON at the repo root as `google_service_account.json`
#      (gitignored). Default path below — change only if you store it elsewhere.
#   4. SHARE your Drive root folder with the service account's `client_email`
#      (looks like `name@project.iam.gserviceaccount.com`) → grant **Viewer**.
#      Without this step the SA sees zero files even though auth works.
#   5. Enable the Drive API:
#         https://console.cloud.google.com/apis/library/drive.googleapis.com
#   6. Run `python ingest.py --drive`. No browser flow. No token expiry.
GOOGLE_SERVICE_ACCOUNT_FILE=google_service_account.json
#
# ▸ MODE B — OAuth user (browser consent flow)
#
#   Leave Mode A's file absent and fill these in instead.
#   1. Create OAuth client ID:
#         https://console.cloud.google.com/apis/credentials
#      → "+ Create credentials" → "OAuth client ID" → type "Desktop app".
#   2. Add `http://localhost` to authorized redirect URIs.
#   3. Enable the Drive API (same link as above).
#   4. On first `ingest.py --drive` run, a browser opens for consent.
#      A `google_token.json` file is saved next to ingest.py and reused
#      on subsequent runs. If the token gets revoked later, the script
#      auto-reopens consent — no manual cleanup needed.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
