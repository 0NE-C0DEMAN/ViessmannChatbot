# ─────────────────────────────────────────────────────────────────────────
# Viessmann RAG Chatbot — environment configuration
# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────

# ── Chat server auth (used by the login screen) ─────────────────────────
CHAT_USERNAME=viessmann
CHAT_PASSWORD=carrier
FLASK_SECRET_KEY=change-me-to-a-random-string
CHAT_PORT=8081

# ── Supabase (Postgres with pgvector) ───────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# ── OpenAI ──────────────────────────────────────────────────────────────
# Get an API key at: https://platform.openai.com/api-keys
# Make sure the account has billing credit (this app uses gpt-4o + gpt-4o-mini)
OPENAI_API_KEY=sk-proj-...

# ── Google Drive (only required when running `ingest.py --drive`) ───────
# Create OAuth credentials in Google Cloud Console:
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create OAuth client ID → type "Desktop app"
#   3. Add `http://localhost` to authorized redirect URIs
#   4. Enable the "Google Drive API" for your project
# On first `ingest.py --drive` run, a browser window will open for consent.
# A `google_token.json` file is then saved next to ingest.py.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ROOT_FOLDER_ID=
POLL_INTERVAL_SECONDS=60
